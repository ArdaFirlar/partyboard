// === Prisma Veritabanı Şeması ===
// Kullanıcı tablosunu tanımlar. Prisma bu dosyadan otomatik SQL oluşturur.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Kayıtlı kullanıcı tablosu
// Misafirler burada saklanmaz, sadece geçici JWT alırlar.
model User {
  id           String       @id @default(cuid())
  email        String       @unique
  username     String
  avatar       String       @default("🎮")
  passwordHash String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  gameResults  GameResult[]
}

// Oyun sonuç tablosu — liderlik için
model GameResult {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameId    String   // "monopoly" veya "rock-paper-scissors"
  won       Int      @default(0)  // 1 = kazandı, 0 = kaybetti
  playedAt  DateTime @default(now())

  @@index([userId, gameId])
}
