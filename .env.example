# === PartyBoard Ortam Değişkenleri ===
# Bu dosyayı kopyalayıp .env olarak kaydet ve değerleri doldur.
# .env dosyası Git'e yüklenmez (güvenlik için).

# Sunucu portu
PORT=3001

# Frontend portları (geliştirme ortamında)
SCREEN_PORT=3000
CONTROLLER_PORT=3002

# PostgreSQL veritabanı bağlantısı (Faz 3'te doldurulacak)
DATABASE_URL=postgresql://user:password@localhost:5432/partyboard

# Redis bağlantısı (Faz 1'de doldurulacak)
REDIS_URL=redis://localhost:6379

# JWT gizli anahtarı (Faz 3'te doldurulacak)
JWT_SECRET=buraya-gizli-anahtar-yaz

# Google OAuth (Faz 3'te doldurulacak)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Ortam (development veya production)
NODE_ENV=development
