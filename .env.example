# === PartyBoard Ortam Değişkenleri ===
# Bu dosyayı kopyalayıp .env olarak kaydet ve değerleri doldur.
# .env dosyası Git'e yüklenmez (güvenlik için).

# ── Geliştirme Ortamı ────────────────────────────────────────────────────

# Sunucu portu
PORT=3001

# Frontend portları (geliştirme ortamında)
SCREEN_PORT=3000
CONTROLLER_PORT=3002

# PostgreSQL veritabanı bağlantısı (yerel geliştirme için)
DATABASE_URL=postgresql://user:password@localhost:5432/partyboard

# JWT gizli anahtarı — uzun ve rastgele bir string olmalı
JWT_SECRET=buraya-gizli-anahtar-yaz

# Ortam
NODE_ENV=development

# ── Production Ortamı (Render + Supabase) ───────────────────────────────
# Aşağıdaki değerler Render dashboard'una girilir, .env'e yazılmaz.

# DATABASE_URL → Supabase project settings → Database → Connection string (URI)
# Örnek: postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# JWT_SECRET → Render otomatik üretir (generateValue: true)

# ALLOWED_ORIGINS → https://partyboard-screen.onrender.com,https://partyboard-controller.onrender.com

# ── Frontend Env Değişkenleri (Render Static Site build sırasında ayarlanır) ──
# VITE_SERVER_URL → https://partyboard-server.onrender.com
